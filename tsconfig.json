{
    "exclude": ["./web", "./dist-web"],
    "compilerOptions": {
       "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022",
        "outDir": "./dist",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "lib": ["es2021"],
        "jsx": "react-jsx",
        "resolveJsonModule": true
    }
}
