{
    "exclude": ["./web", "./dist-web"],
    "compilerOptions": {
        "target": "ES2016",
        "outDir": "./dist",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "module": "CommonJS",
        "moduleResolution": "bundler",
        "lib": ["es2021"],
        "jsx": "react-jsx",
        "resolveJsonModule": true
    }
}
